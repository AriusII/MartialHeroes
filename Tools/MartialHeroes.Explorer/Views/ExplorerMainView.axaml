<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MartialHeroes.Explorer.ViewModels"
             xmlns:loc="using:MartialHeroes.Explorer.Localization"
             xmlns:shared="using:MartialHeroes.Tools.Shared.Localization"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="MartialHeroes.Explorer.Views.ExplorerMainView"
             x:DataType="vm:ExplorerMainViewModel">

	<DockPanel Background="{DynamicResource AppWindowBrush}">

		<!-- ── Top header bar ── -->
		<Border DockPanel.Dock="Top" Classes="toolbar">
			<DockPanel>
				<Button DockPanel.Dock="Right"
				        Command="{Binding GoToSettingsCommand}"
				        VerticalAlignment="Center"
				        Padding="10,6" CornerRadius="5">
					<StackPanel Orientation="Horizontal" Spacing="5">
						<TextBlock Text="⚙" FontSize="14" VerticalAlignment="Center" />
						<TextBlock Text="{x:Static shared:SharedStrings.Settings}"
						           FontSize="13" VerticalAlignment="Center" />
					</StackPanel>
				</Button>
				<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
					<TextBlock Text="⚔️" FontSize="18" VerticalAlignment="Center" />
					<TextBlock Text="{x:Static loc:ExplorerStrings.AppTitle}"
					           FontSize="15" FontWeight="SemiBold"
					           Foreground="{DynamicResource AppForegroundBrush}"
					           VerticalAlignment="Center" />
				</StackPanel>
			</DockPanel>
		</Border>

		<!-- ── Bottom status bar ── -->
		<Border DockPanel.Dock="Bottom" Classes="statusBar">
			<DockPanel>
				<TextBlock DockPanel.Dock="Left"
				           Text="{Binding RecordEditor.StatusMessage}"
				           FontSize="12"
				           Foreground="{DynamicResource AppForegroundSecondaryBrush}"
				           VerticalAlignment="Center" />
				<StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="14"
				            VerticalAlignment="Center">
					<TextBlock Text="{Binding RecordEditor.ModificationDisplayText}"
					           FontSize="12"
					           Foreground="{DynamicResource AppAmberBrush}"
					           FontWeight="SemiBold"
					           VerticalAlignment="Center"
					           IsVisible="{Binding RecordEditor.IsDirty}" />
					<TextBlock Text="{Binding RecordEditor.CurrentFileName}"
					           FontSize="12"
					           Foreground="{DynamicResource AppForegroundTertiaryBrush}"
					           VerticalAlignment="Center"
					           IsVisible="{Binding RecordEditor.IsFileLoaded}" />
				</StackPanel>
				<Panel />
			</DockPanel>
		</Border>

		<!-- ── Main content: sidebar + splitter + editor ── -->
		<Grid ColumnDefinitions="260,1,*">
			<ContentControl Grid.Column="0" Content="{Binding FileBrowser}"
			                MinWidth="180" MaxWidth="480" />
			<GridSplitter Grid.Column="1" ResizeDirection="Columns"
			              Background="{DynamicResource AppSeparatorBrush}" />
			<ContentControl Grid.Column="2" Content="{Binding RecordEditor}" />
		</Grid>

	</DockPanel>
</UserControl>