<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MartialHeroes.Explorer.ViewModels"
             xmlns:loc="using:MartialHeroes.Explorer.Localization"
             mc:Ignorable="d" d:DesignWidth="280" d:DesignHeight="700"
             x:Class="MartialHeroes.Explorer.Views.FileBrowserView"
             x:DataType="vm:FileBrowserViewModel">

	<Border Classes="sidebar">
		<DockPanel>

			<!-- Sidebar header -->
			<Border DockPanel.Dock="Top"
			        Background="{DynamicResource AppToolbarBrush}"
			        BorderBrush="{DynamicResource AppBorderBrush}"
			        BorderThickness="0,0,0,1"
			        Padding="14,10">
				<StackPanel Orientation="Horizontal" Spacing="8">
					<TextBlock Text="📂" FontSize="15" VerticalAlignment="Center" />
					<TextBlock Text="{x:Static loc:ExplorerStrings.Files}"
					           FontSize="13" FontWeight="SemiBold"
					           Foreground="{DynamicResource AppForegroundBrush}"
					           VerticalAlignment="Center" />
				</StackPanel>
			</Border>

			<!-- File tree -->
			<ScrollViewer VerticalScrollBarVisibility="Auto">
				<TreeView ItemsSource="{Binding RootNodes}"
				          SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
				          Padding="6,6"
				          Background="Transparent"
				          BorderThickness="0">
					<TreeView.Styles>
						<Style Selector="TreeViewItem">
							<Setter Property="IsExpanded" Value="True" />
						</Style>
					</TreeView.Styles>
					<TreeView.ItemTemplate>
						<TreeDataTemplate ItemsSource="{Binding Children}"
						                  x:DataType="vm:FileNodeViewModel">
							<Panel>

								<!-- ── CATEGORY NODE ── -->
								<Border IsVisible="{Binding IsCategory}"
								        Classes="categoryNode"
								        Margin="0,3,0,0">
									<StackPanel Orientation="Horizontal" Spacing="6">
										<TextBlock Text="{Binding Icon}" FontSize="13"
										           VerticalAlignment="Center" />
										<TextBlock Text="{Binding FileName}"
										           FontWeight="SemiBold" FontSize="12"
										           Foreground="{DynamicResource AppForegroundBrush}"
										           VerticalAlignment="Center" />
										<Border Classes="countBadge" VerticalAlignment="Center">
											<TextBlock Text="{Binding FileCountDisplay}"
											           FontSize="11"
											           Foreground="{DynamicResource AppForegroundSecondaryBrush}" />
										</Border>
									</StackPanel>
								</Border>

								<!-- ── FILE NODE ── -->
								<Grid IsVisible="{Binding !IsCategory}"
								      ColumnDefinitions="Auto,*,Auto"
								      Margin="0,1"
								      ToolTip.Tip="{Binding FilePathTooltip}">

									<!-- File icon -->
									<TextBlock Grid.Column="0" Text="📄" FontSize="12"
									           VerticalAlignment="Top" Margin="0,2,7,0" />

									<!-- Filename + path -->
									<StackPanel Grid.Column="1" Spacing="1">
										<TextBlock Text="{Binding FileName}"
										           FontSize="13" FontWeight="Medium"
										           Foreground="{DynamicResource AppForegroundBrush}"
										           TextTrimming="CharacterEllipsis" />
										<TextBlock Text="{Binding FilePath}"
										           FontSize="11"
										           Foreground="{DynamicResource AppForegroundTertiaryBrush}"
										           TextTrimming="CharacterEllipsis"
										           FontFamily="Cascadia Mono,Consolas,monospace"
										           MaxWidth="170" />
									</StackPanel>

									<!-- Dirty dot -->
									<Ellipse Grid.Column="2" Width="7" Height="7"
									         Fill="{DynamicResource AppAmberBrush}"
									         VerticalAlignment="Center" Margin="6,0,0,0"
									         IsVisible="{Binding IsDirty}" />
								</Grid>

							</Panel>
						</TreeDataTemplate>
					</TreeView.ItemTemplate>
				</TreeView>
			</ScrollViewer>

		</DockPanel>
	</Border>
</UserControl>