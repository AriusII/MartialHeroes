<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:MartialHeroes.Packer.ViewModels"
             xmlns:loc="using:MartialHeroes.Packer.Localization"
             xmlns:shared="using:MartialHeroes.Tools.Shared.Localization"
             mc:Ignorable="d" d:DesignWidth="780" d:DesignHeight="560"
             x:Class="MartialHeroes.Packer.Views.PackerMainView"
             x:DataType="vm:PackerMainViewModel">

	<DockPanel Background="{DynamicResource AppWindowBrush}">

		<!-- ── Header bar ── -->
		<Border DockPanel.Dock="Top" Classes="toolbar">
			<DockPanel>
				<Button DockPanel.Dock="Right"
				        Command="{Binding GoToSettingsCommand}"
				        VerticalAlignment="Center"
				        CornerRadius="6" Padding="12,7">
					<StackPanel Orientation="Horizontal" Spacing="5">
						<TextBlock Text="⚙" FontSize="14" VerticalAlignment="Center" />
						<TextBlock Text="{x:Static shared:SharedStrings.Settings}"
						           FontSize="13" VerticalAlignment="Center" />
					</StackPanel>
				</Button>
				<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
					<TextBlock Text="📦" FontSize="20" VerticalAlignment="Center" />
					<TextBlock Text="{x:Static loc:PackerStrings.AppTitle}"
					           FontSize="17" FontWeight="SemiBold"
					           Foreground="{DynamicResource AppForegroundBrush}"
					           VerticalAlignment="Center" />
				</StackPanel>
			</DockPanel>
		</Border>

		<!-- ── Two-column card layout ── -->
		<Grid Margin="20,16,20,20" ColumnDefinitions="*,16,*">

			<!-- ──────────────────── EXTRACTION card ──────────────────── -->
			<!--
                Padding="0" + ClipToBounds="True" lets the 4 px left stripe fill
                the full card height while being clipped by CornerRadius="10".
            -->
			<Border Grid.Column="0" Classes="card" Padding="0" ClipToBounds="True">
				<Grid ColumnDefinitions="4,*">

					<!-- Green left stripe -->
					<Border Grid.Column="0" Classes="accentStripeGreen" />

					<!-- Card content -->
					<DockPanel Grid.Column="1" Margin="18,18,18,18">

						<!-- Section header -->
						<StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
						            Spacing="8" Margin="0,0,0,16">
							<TextBlock Text="📤" FontSize="18" VerticalAlignment="Center" />
							<TextBlock Text="{x:Static loc:PackerStrings.Extraction}"
							           Classes="sectionHeader green" VerticalAlignment="Center" />
						</StackPanel>

						<!-- Button + status at bottom -->
						<StackPanel DockPanel.Dock="Bottom" Margin="0,14,0,0" Spacing="6">

							<Button Command="{Binding ExtractCommand}"
							        IsVisible="{Binding !IsExtracting}"
							        HorizontalAlignment="Stretch"
							        HorizontalContentAlignment="Center"
							        Classes="accent action">
								<StackPanel Orientation="Horizontal" Spacing="7">
									<TextBlock Text="▶" FontSize="11" VerticalAlignment="Center" />
									<TextBlock Text="{x:Static loc:PackerStrings.StartExtraction}" />
								</StackPanel>
							</Button>

							<Button Command="{Binding ExtractCancelCommand}"
							        IsVisible="{Binding IsExtracting}"
							        HorizontalAlignment="Stretch"
							        HorizontalContentAlignment="Center"
							        Classes="cancel">
								<StackPanel Orientation="Horizontal" Spacing="7">
									<TextBlock Text="⏹" FontSize="11" VerticalAlignment="Center" />
									<TextBlock Text="{x:Static shared:SharedStrings.Cancel}" />
								</StackPanel>
							</Button>

							<TextBlock Text="{Binding ExtractStatus}"
							           FontSize="12" TextWrapping="Wrap"
							           TextAlignment="Center"
							           Foreground="{DynamicResource AppForegroundSecondaryBrush}"
							           IsVisible="{Binding ExtractStatus,
                                           Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
						</StackPanel>

						<!-- Paths + progress body -->
						<StackPanel Spacing="10">

							<StackPanel Spacing="4">
								<TextBlock Text="data.inf" FontSize="11" FontWeight="SemiBold"
								           Foreground="{DynamicResource AppForegroundSecondaryBrush}" />
								<Border Classes="pathDisplay">
									<TextBlock Text="{Binding InfPath}" ToolTip.Tip="{Binding InfPath}" />
								</Border>
							</StackPanel>

							<StackPanel Spacing="4">
								<TextBlock Text="data.vfs" FontSize="11" FontWeight="SemiBold"
								           Foreground="{DynamicResource AppForegroundSecondaryBrush}" />
								<Border Classes="pathDisplay">
									<TextBlock Text="{Binding VfsPath}" ToolTip.Tip="{Binding VfsPath}" />
								</Border>
							</StackPanel>

							<StackPanel Spacing="4">
								<TextBlock Text="{x:Static loc:PackerStrings.Destination}"
								           FontSize="11" FontWeight="SemiBold"
								           Foreground="{DynamicResource AppForegroundSecondaryBrush}" />
								<Border Classes="pathDisplay">
									<TextBlock Text="{Binding ExtractTargetPath}"
									           ToolTip.Tip="{Binding ExtractTargetPath}" />
								</Border>
							</StackPanel>

							<!-- Progress (visible while extracting) -->
							<StackPanel Spacing="5" IsVisible="{Binding IsExtracting}">
								<Grid ColumnDefinitions="*,Auto">
									<ProgressBar Grid.Column="0" Classes="custom"
									             Minimum="0" Maximum="{Binding ExtractTotal}"
									             Value="{Binding ExtractCurrent}" />
									<TextBlock Grid.Column="1" Margin="8,0,0,0"
									           FontSize="11" FontWeight="SemiBold"
									           Foreground="{DynamicResource AppForegroundSecondaryBrush}"
									           VerticalAlignment="Center">
										<TextBlock.Text>
											<MultiBinding StringFormat="{}{0} / {1}">
												<Binding Path="ExtractCurrent" />
												<Binding Path="ExtractTotal" />
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</Grid>
								<TextBlock Text="{Binding ExtractCurrentFile}"
								           FontSize="11" TextTrimming="CharacterEllipsis"
								           Foreground="{DynamicResource AppForegroundTertiaryBrush}"
								           FontFamily="Cascadia Mono,Consolas,monospace"
								           ToolTip.Tip="{Binding ExtractCurrentFile}" />
							</StackPanel>

						</StackPanel>
					</DockPanel>
				</Grid>
			</Border>

			<!-- ──────────────────── REPACK card ──────────────────── -->
			<Border Grid.Column="2" Classes="card" Padding="0" ClipToBounds="True">
				<Grid ColumnDefinitions="4,*">

					<!-- Blue left stripe -->
					<Border Grid.Column="0" Classes="accentStripeBlue" />

					<!-- Card content -->
					<DockPanel Grid.Column="1" Margin="18,18,18,18">

						<!-- Section header -->
						<StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
						            Spacing="8" Margin="0,0,0,16">
							<TextBlock Text="📥" FontSize="18" VerticalAlignment="Center" />
							<TextBlock Text="{x:Static loc:PackerStrings.Repack}"
							           Classes="sectionHeader blue" VerticalAlignment="Center" />
						</StackPanel>

						<!-- Button + status at bottom -->
						<StackPanel DockPanel.Dock="Bottom" Margin="0,14,0,0" Spacing="6">

							<Button Command="{Binding RepackCommand}"
							        IsVisible="{Binding !IsRepacking}"
							        HorizontalAlignment="Stretch"
							        HorizontalContentAlignment="Center"
							        Classes="accent action">
								<StackPanel Orientation="Horizontal" Spacing="7">
									<TextBlock Text="▶" FontSize="11" VerticalAlignment="Center" />
									<TextBlock Text="{x:Static loc:PackerStrings.StartRepack}" />
								</StackPanel>
							</Button>

							<Button Command="{Binding RepackCancelCommand}"
							        IsVisible="{Binding IsRepacking}"
							        HorizontalAlignment="Stretch"
							        HorizontalContentAlignment="Center"
							        Classes="cancel">
								<StackPanel Orientation="Horizontal" Spacing="7">
									<TextBlock Text="⏹" FontSize="11" VerticalAlignment="Center" />
									<TextBlock Text="{x:Static shared:SharedStrings.Cancel}" />
								</StackPanel>
							</Button>

							<TextBlock Text="{Binding RepackStatus}"
							           FontSize="12" TextWrapping="Wrap"
							           TextAlignment="Center"
							           Foreground="{DynamicResource AppForegroundSecondaryBrush}"
							           IsVisible="{Binding RepackStatus,
                                           Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
						</StackPanel>

						<!-- Paths + warning + progress body -->
						<StackPanel Spacing="10">

							<StackPanel Spacing="4">
								<TextBlock Text="{x:Static loc:PackerStrings.Source}"
								           FontSize="11" FontWeight="SemiBold"
								           Foreground="{DynamicResource AppForegroundSecondaryBrush}" />
								<Border Classes="pathDisplay">
									<TextBlock Text="{Binding RepackSourcePath}"
									           ToolTip.Tip="{Binding RepackSourcePath}" />
								</Border>
							</StackPanel>

							<StackPanel Spacing="4">
								<TextBlock Text="{x:Static loc:PackerStrings.Destination}"
								           FontSize="11" FontWeight="SemiBold"
								           Foreground="{DynamicResource AppForegroundSecondaryBrush}" />
								<Border Classes="pathDisplay">
									<TextBlock Text="{Binding RepackTargetPath}"
									           ToolTip.Tip="{Binding RepackTargetPath}" />
								</Border>
							</StackPanel>

							<!-- Warning notice -->
							<Border Classes="warningBox">
								<StackPanel Orientation="Horizontal" Spacing="8">
									<TextBlock Text="⚠" FontSize="13"
									           Foreground="{DynamicResource AppAmberBrush}"
									           VerticalAlignment="Top" Margin="0,1,0,0" />
									<TextBlock Text="{x:Static loc:PackerStrings.RepackWarning}"
									           FontSize="12" TextWrapping="Wrap"
									           Foreground="{DynamicResource AppForegroundSecondaryBrush}" />
								</StackPanel>
							</Border>

							<!-- Progress (visible while repacking) -->
							<StackPanel Spacing="5" IsVisible="{Binding IsRepacking}">
								<Grid ColumnDefinitions="*,Auto">
									<ProgressBar Grid.Column="0" Classes="custom"
									             Minimum="0" Maximum="{Binding RepackTotal}"
									             Value="{Binding RepackCurrent}" />
									<TextBlock Grid.Column="1" Margin="8,0,0,0"
									           FontSize="11" FontWeight="SemiBold"
									           Foreground="{DynamicResource AppForegroundSecondaryBrush}"
									           VerticalAlignment="Center">
										<TextBlock.Text>
											<MultiBinding StringFormat="{}{0} / {1}">
												<Binding Path="RepackCurrent" />
												<Binding Path="RepackTotal" />
											</MultiBinding>
										</TextBlock.Text>
									</TextBlock>
								</Grid>
								<TextBlock Text="{Binding RepackCurrentFile}"
								           FontSize="11" TextTrimming="CharacterEllipsis"
								           Foreground="{DynamicResource AppForegroundTertiaryBrush}"
								           FontFamily="Cascadia Mono,Consolas,monospace"
								           ToolTip.Tip="{Binding RepackCurrentFile}" />
							</StackPanel>

						</StackPanel>
					</DockPanel>
				</Grid>
			</Border>

		</Grid>
	</DockPanel>
</UserControl>